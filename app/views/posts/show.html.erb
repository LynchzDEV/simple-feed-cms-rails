<!-- app/views/posts/show.html.erb -->
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <% if notice.present? %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4" role="alert">
      <p><%= notice %></p>
    </div>
  <% end %>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
    <div class="px-4 py-5 sm:px-6 border-b">
      <h1 class="text-2xl font-bold"><%= @post.title %></h1>
      <p class="text-gray-500 text-sm mt-1">Posted <%= time_ago_in_words(@post.created_at) %> ago</p>
    </div>
    <div class="px-4 py-5 sm:p-6">
      <div class="prose max-w-none">
        <%= simple_format(@post.content) %>
      </div>
    </div>
  </div>

  <div class="flex space-x-4">
    <%= link_to 'Edit', edit_post_path(@post), class: "bg-yellow-500 hover:bg-yellow-700 text-white font-bold py-2 px-4 rounded" %>
    <%= link_to 'Back', posts_path, class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
  </div>
</div>
