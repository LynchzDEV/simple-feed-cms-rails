<!-- app/views/videos/index.html.erb -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Videos</h1>
    <%= link_to 'New Video', new_video_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
  </div>

  <% if notice.present? %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4" role="alert">
      <p><%= notice %></p>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @videos.each do |video| %>
      <div class="bg-white overflow-hidden shadow-sm rounded-lg border">
        <div class="bg-gray-200 h-48 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="p-4">
          <h2 class="text-xl font-semibold mb-2"><%= video.title %></h2>
          <p class="text-gray-500 text-sm mb-2"><%= video.created_at.strftime("%B %d, %Y") %></p>
          <p class="text-gray-700 mb-4 line-clamp-2"><%= video.content %></p>
          <div class="flex justify-between">
            <p class="text-sm text-gray-500">File: <%= File.basename(video.file) %></p>
            <div class="flex space-x-2">
              <%= link_to 'View', video, class: "text-blue-600 hover:text-blue-800" %>
              <%= link_to 'Edit', edit_video_path(video), class: "text-yellow-600 hover:text-yellow-800" %>
              <%= link_to 'Delete', video, method: :delete, data: { confirm: 'Are you sure?' }, class: "text-red-600 hover:text-red-800" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
