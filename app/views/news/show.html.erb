<!-- app/views/news/show.html.erb -->
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <% if notice.present? %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4" role="alert">
      <p><%= notice %></p>
    </div>
  <% end %>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
    <div class="px-4 py-5 sm:px-6 border-b">
      <h1 class="text-2xl font-bold"><%= @news.title %></h1>
      <p class="text-gray-500 text-sm mt-1">Published <%= time_ago_in_words(@news.created_at) %> ago</p>
    </div>
    <div class="px-4 py-5 sm:p-6">
      <div class="prose max-w-none mb-6">
        <%= simple_format(@news.content) %>
      </div>

      <div class="mt-4 p-4 bg-gray-100 rounded-md">
        <p class="text-sm text-gray-700">Source:
          <a href="<%= @news.reference %>" target="_blank" class="text-blue-600 hover:underline"><%= @news.reference %></a>
        </p>
      </div>
    </div>
  </div>

  <div class="flex space-x-4">
    <%= link_to 'Edit', edit_news_path(@news), class: "bg-yellow-500 hover:bg-yellow-700 text-white font-bold py-2 px-4 rounded" %>
    <%= link_to 'Back', news_index_path, class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
  </div>
</div>
