<!-- app/views/news/index.html.erb -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">News</h1>
    <%= link_to 'New News Item', new_news_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
  </div>

  <% if notice.present? %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4" role="alert">
      <p><%= notice %></p>
    </div>
  <% end %>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <ul class="divide-y divide-gray-200">
      <% @news_items.each do |news| %>
        <li class="px-6 py-4">
          <div>
            <h2 class="text-xl font-semibold"><%= news.title %></h2>
            <p class="text-gray-500 text-sm mb-2"><%= news.created_at.strftime("%B %d, %Y") %></p>
            <p class="text-gray-700 mb-2 line-clamp-2"><%= news.content %></p>
            <div class="flex justify-between items-center">
              <a href="<%= news.reference %>" target="_blank" class="text-blue-600 hover:underline text-sm">Source: <%= URI.parse(news.reference).host %></a>
              <div class="flex space-x-2">
                <%= link_to 'View', news, class: "text-blue-600 hover:text-blue-800" %>
                <%= link_to 'Edit', edit_news_path(news), class: "text-yellow-600 hover:text-yellow-800" %>
                <%= link_to 'Delete', news, method: :delete, data: { confirm: 'Are you sure?' }, class: "text-red-600 hover:text-red-800" %>
              </div>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
</div>
